# Copy this file to .env — dotenv loads it automatically on startup (via `import 'dotenv/config'` in server.ts).

# HTTP port the Express server listens on
PORT=3001

# N — every Nth order opens the discount code generation window
# Must be a positive integer. Set to 2 for quick local testing.
DISCOUNT_ORDER_INTERVAL=5

# X — discount percentage applied by generated codes (1–100)
DISCOUNT_PERCENT=10
